# Server
PORT=4000
NODE_ENV=development

# Subgraph URLs
AUTH_SERVICE_URL=http://localhost:3002/graphql
RESTAURANT_SERVICE_URL=http://localhost:3001/graphql
ORDER_SERVICE_URL=http://localhost:3000/graphql
DELIVERY_SERVICE_URL=http://localhost:3003/graphql

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
