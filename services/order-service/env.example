# Order Service Environment Variables

# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_db

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=order-service
KAFKA_GROUP_ID=order-service-group

# Kafka Topics
KAFKA_TOPIC_ORDER_CREATED=order.created
KAFKA_TOPIC_ORDER_ASSIGNED=order.assigned
KAFKA_TOPIC_ORDER_DELIVERED=order.delivered

# JWT (para validar tokens del API Gateway)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Logging
LOG_LEVEL=info

