{
  "uid": "food-delivery-containers",
  "title": "Container Resources (cAdvisor)",
  "tags": ["docker", "cadvisor"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage per Container (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"(order|restaurant|auth|delivery|notification|api-gateway).*\",name!=\"\"}[1m])) by (name) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage per Container (MB)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "decmbytes", "min": 0},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"(order|restaurant|auth|delivery|notification|api-gateway).*\",name!=\"\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Network Received (bytes/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "Bps", "min": 0},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=~\"(order|restaurant|auth|delivery|notification|api-gateway).*\",name!=\"\"}[1m])) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Transmitted (bytes/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "Bps", "min": 0},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=~\"(order|restaurant|auth|delivery|notification|api-gateway).*\",name!=\"\"}[1m])) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Container Restarts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 16},
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 3}]}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(container_last_seen{name=~\"(order|restaurant|auth|delivery|notification|api-gateway).*\",name!=\"\"}) by (name) * 0",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
